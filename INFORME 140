\title{\textbf{Interferencia y Difracción en Rendijas Simples y Dobles}}
\author{ Gabriel Cifuentes Barraza, 22.078.757-5, gcifuentes@usm.cl, JUEVES 3-4.\\
AWEONAO CULIAO ORTIZ, 2x.6xx.4xx-x, xxxx@usm.cl, JUEVES 3-4.}
\date{}
